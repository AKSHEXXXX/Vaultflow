# =============================================================================
# .env.example — Local Development Environment Variables
# Copy this file to .env (which is .gitignored) and fill in your values.
# =============================================================================

# ----- Database (matches docker-compose.yml dev stack) -----
DATABASE_URL=jdbc:postgresql://localhost:5432/saas_db
DATABASE_USERNAME=saas_user
DATABASE_PASSWORD=saas_password

# ----- JWT -----
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=REDACTED_JWT_SECRET

# ----- Google OAuth2 -----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth/callback

# ----- AWS S3 (LocalStack defaults for local dev) -----
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_S3_BUCKET=saas-documents-dev
AWS_S3_ENDPOINT=http://localhost:4566

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  (leave blank for dev — no auth in dev Redis)
