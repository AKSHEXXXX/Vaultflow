# =============================================================================
# .env.prod.example — Production Environment Variables (EC2 / docker-compose.prod.yml)
# Copy to .env.prod on your EC2 instance (NEVER commit the real file).
# All variables are REQUIRED unless marked optional.
# =============================================================================

# ----- PostgreSQL (used by both postgres service and backend service) -----
POSTGRES_DB=saas_db
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Spring datasource (backend reads these; URL built from POSTGRES_* above in docker-compose.prod.yml)
DATABASE_URL=jdbc:postgresql://postgres:5432/saas_db
DATABASE_USERNAME=saas_user
DATABASE_PASSWORD=CHANGE_ME_strong_db_password

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ----- JWT -----
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# ----- Google OAuth2 -----
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include: https://your-domain.com/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Frontend URL that receives the JWT after OAuth2 handshake
OAUTH2_REDIRECT_URI=https://your-domain.com/oauth/callback

# ----- S3 Storage (MinIO — self-hosted, runs inside Docker alongside the app) -----
# These double as MinIO root credentials AND the AWS SDK client credentials.
# Use any strong values — they only need to match each other (not a real AWS account).
# AWS_S3_ENDPOINT is set automatically in docker-compose.prod.yml (http://minio:9000)
AWS_ACCESS_KEY_ID=CHANGE_ME_minio_access_key
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret_key_min_8_chars
AWS_REGION=us-east-1
AWS_S3_BUCKET=saas-documents-prod

# ----- Docker Image (set by GitHub Actions CI/CD, override manually if needed) -----
DOCKER_IMAGE=your-dockerhub-username/saas-backend
IMAGE_TAG=latest

# ----- EC2 Deployment (used by scripts/deploy.sh and GitHub Actions) -----
# These are NOT passed to the container — they're only for the deploy script
EC2_HOST=your-ec2-public-ip-or-domain
EC2_USER=ubuntu
# EC2_SSH_KEY is set as a GitHub Actions secret (not here)
